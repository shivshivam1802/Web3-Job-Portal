{
  "name": "web3-freelance-marketplace",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "contracts",
    "backend",
    "frontend"
  ],
  "scripts": {
    "contracts:build": "npm run compile --workspace=contracts",
    "contracts:test": "npm run test --workspace=contracts",
    "backend:dev": "npm run start:dev --workspace=backend",
    "backend:build": "npm run build --workspace=backend",
    "frontend:dev": "npm run dev --workspace=frontend",
    "frontend:build": "npm run build --workspace=frontend",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down"
  }
}
